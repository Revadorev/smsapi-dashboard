{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "env": {
    "SMSAPI_TOKEN": "@smsapi_token",
    "SMSAPI_SENDER": "@smsapi_sender",
